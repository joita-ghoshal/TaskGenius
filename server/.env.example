# Server Configuration
# Server Configuration
PORT=5000
NODE_ENV=development

# PostgreSQL (Supabase/Neon/Render)
# Local: postgresql://postgres:password@localhost:5432/taskgenius
# Supabase: postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
# Neon: postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb
DATABASE_URL=postgresql://postgres:password@localhost:5432/taskgenius

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Email (optional - for email notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
